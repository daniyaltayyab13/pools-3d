generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Design {
  id             String   @id @default(uuid())
  name           String?
  shape          String
  length         Float
  width          Float
  depth          Float
  poolTile       String
  coping         String
  deck           String
  water          String
  source         String   @default("studio")
  config         Json
  previewSummary Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  leads          Lead[]

  @@index([createdAt])
}

model Lead {
  id           String   @id @default(uuid())

  customerName String
  email        String?
  phone        String?
  city         String?
  message      String?

  designId     String?
  design       Design?  @relation(fields: [designId], references: [id], onDelete: SetNull)

  config       Json
  source       String   @default("studio")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
  @@index([designId])
}
